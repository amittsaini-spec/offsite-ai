// Offsite.ai data model.
// SQLite for instant local dev. To go to production, change provider to
// "postgresql" and DATABASE_URL — no code changes needed (JSON stored as text).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Home-page CMS ──────────────────────────────────────────────
// Everything on the public home page is editable; defaults match the
// hardcoded copy that used to live in src/app/page.tsx so the page
// renders identically when nothing has been overridden.

model SiteSettings {
  id                 String   @id @default("home")
  heroEyebrow        String   @default("")
  heroHeadline       String   @default("")   // *asterisks* render as <em>
  heroSubhead        String   @default("")
  heroMediaType      String   @default("none")   // none | image | video | slideshow
  heroMedia          String   @default("[]")     // JSON array of URLs (slideshow uses all)
  heroVideoEmbed     String   @default("")       // optional YouTube/Vimeo URL when type=video
  heroPoster         String   @default("")       // poster image for video — also the mobile / reduced-motion fallback
  searchPlaceholders String   @default("{}")     // JSON { where, event, date, guests }
  valueCards         String   @default("[]")     // JSON [{ figure, title, desc }]
  ctaHeadline        String   @default("")
  ctaBody            String   @default("")
  ctaButtonLabel     String   @default("")
  ctaButtonLink      String   @default("")
  footerTagline      String   @default("")
  updatedAt          DateTime @updatedAt
}

model HomeCollection {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  imageUrl  String   @default("")
  linkType  String   @default("type")  // "type" | "tag"
  linkValue String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model HomeSection {
  id          String   @id @default(cuid())
  title       String
  subtitle    String
  filterType  String   @default("tag")  // "tag" | "type" | "featured"
  filterValue String   @default("")
  sortOrder   Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// DestaLabs team members who act as the agent managing all hotels.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("AGENT") // AGENT | ADMIN
  createdAt    DateTime @default(now())
  hotels       Hotel[]
}

model Hotel {
  id          String   @id @default(cuid())
  name        String
  brand        String   @default("")  // chain / brand (optional)
  description  String   @default("")

  // Location
  // Market is the launch destination — one of: Cancún, Cabo San Lucas,
  // San Miguel de Allende, Puerto Vallarta. Constraint enforced in the
  // server actions (normalizeMarket) since SQLite/Postgres parity rules
  // out a Prisma enum here.
  market       String   @default("Cancún")
  address      String   @default("")  // full street address
  city         String
  region       String   @default("")  // state / province
  country      String   @default("")
  zone         String   @default("")  // legacy free-form zone, still surfaced
  latitude     Float?
  longitude    Float?

  // Contact
  contactName  String   @default("")
  contactEmail String   @default("")
  contactPhone String   @default("")
  website      String   @default("")

  // Profile
  amenities    String   @default("[]")  // JSON array of amenity keys
  starRating   Int?

  createdAt    DateTime @default(now())
  // SetNull on delete so removing a team member doesn't cascade away
  // hotels they created — the hotel survives with an empty owner pointer.
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById  String?
  venues       Venue[]
}

model Venue {
  id          String   @id @default(cuid())
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  hotelId     String
  name        String
  type        String   // Garden | Beachfront | Oceanfront | Ballroom | Rooftop | Poolside | Chapel | Cenote
  description String   @default("")
  sqft        Int      @default(0)
  seated      Int      @default(0)
  standing    Int      @default(0)
  basePrice   Int      @default(0)   // DEPRECATED: legacy single-price field, kept for backfill
  depositPct  Int      @default(25)
  status      String   @default("PUBLISHED") // DRAFT | PUBLISHED
  tags           String @default("[]")  // JSON array of strings
  included       String @default("[]")  // JSON array of strings
  layouts        String @default("{}")  // JSON object { Ceremony: 200, ... }
  rules          String @default("{}")  // JSON object { cancel, time, catering, min }
  pricingOptions String @default("[]")  // JSON array of { label, durationHours, price }

  // Media (Phase 4)
  photos         String @default("[]")  // JSON array of URLs; index 0 is cover
  videoUrl       String @default("")    // Vercel Blob URL or YouTube/Vimeo embed URL
  tourUrl        String @default("")    // Matterport / 360° URL
  floorPlans     String @default("[]")  // JSON array of URLs

  // Availability — admin-set blocked dates (YYYY-MM-DD), excluding CONFIRMED bookings
  blackoutDates  String @default("[]")
  createdAt   DateTime @default(now())
  bookings    BookingRequest[]
}

model BookingRequest {
  id         String    @id @default(cuid())
  venue      Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId    String
  messages   Message[]
  guestName  String
  guestEmail String
  eventType  String   @default("Wedding")
  eventDate  String   @default("")
  guests     Int      @default(0)
  tierLabel  String   @default("Half-day · 4 hours")
  basePrice  Int      @default(0)
  serviceFee Int      @default(0)
  depositDue Int      @default(0)
  total      Int      @default(0)
  // REQUESTED | CONFIRMED | DEPOSIT_HELD | COMPLETED | DECLINED | CANCELLED
  status     String   @default("REQUESTED")
  // Internal notes — JSON array of { author, text, at } for the ops timeline.
  notes      String   @default("[]")
  // Payouts (concierge-first; STRIPE SEAM lives in actions.markPayoutAction).
  payoutStatus  String    @default("PENDING")  // PENDING | PAID
  payoutPaidAt  DateTime?
  payoutNote    String    @default("")
  createdAt  DateTime @default(now())
}

// Outward-facing conversation thread per booking. Agents post messages
// here; we record received messages from the guest or hotel under the
// same model so the timeline reads as a single chronological feed.
// Internal-only notes live on BookingRequest.notes (Phase 5.2).
model Message {
  id        String   @id @default(cuid())
  booking   BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String
  sender    String   // "agent" | "guest" | "hotel"
  body      String
  createdAt DateTime @default(now())
}
