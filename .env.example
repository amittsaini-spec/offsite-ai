# SQLite for local dev. For production, swap to Postgres/Supabase:
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/offsite?schema=public"
DATABASE_URL="file:./dev.db"

# Used to sign session cookies. Generate a real one: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# Seed admin login
SEED_ADMIN_EMAIL="admin@destalabs.com"
SEED_ADMIN_PASSWORD="destalabs2026"

# Google Maps key for hotel address autocomplete + map preview.
# Enable "Maps JavaScript API" and "Places API" in Google Cloud, then paste here.
# Restrict the key to your domains (localhost + your Vercel domain).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Vercel Blob storage for venue photos / videos / floor plans.
# 1) In your Vercel project: Storage → Create → Blob → name it "offsite-media".
# 2) Vercel will auto-add BLOB_READ_WRITE_TOKEN to your project env. Copy it here too.
# 3) Set NEXT_PUBLIC_BLOB_READY=true so the upload UI shows up in the admin forms.
BLOB_READ_WRITE_TOKEN=""
NEXT_PUBLIC_BLOB_READY="false"
